# JWT Secrets — Generate in production: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
COOKIE_SECRET=

# PII Encryption Key — 64-char hex. Required in production.
ENCRYPTION_KEY=

# Token expiry
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database URL (Railway auto-injects this)
DATABASE_URL=postgresql://user:password@host:5432/db

# Postgres SSL (Railway: require)
# PGSSLMODE=require

PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development
