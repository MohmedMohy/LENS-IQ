JWT_SECRET=your_super_secret_key_here

# Either set DATABASE_URL (Railway auto-provides this):
DATABASE_URL=postgresql://postgres:password@localhost:5432/car_financing_system

# Or set individual vars (fallback):
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=car_financing_system
# DB_PASSWORD=admin123
# DB_PORT=5432

# PGSSLMODE controls SSL behavior:
#   disable   — no SSL (local dev)
#   require   — SSL required, reject unauthorized
#   no-verify — SSL required, skip cert verification (Railway default)
#   prefer    — try SSL first, fallback to plain (default in production)

PORT=3000
