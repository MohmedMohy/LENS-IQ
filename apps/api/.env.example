# JWT Secret — CHANGE THIS in production
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Database URL (Railway auto-injects this)
DATABASE_URL=postgresql://user:password@host:5432/db

# PGSSLMODE controls SSL behavior (optional — not needed for Railway):
#   disable   — no SSL (default)
#   require   — SSL required, reject unauthorized
#   no-verify — SSL required, skip cert verification
#   prefer    — try SSL first, fallback to plain
# PGSSLMODE=disable

PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development
