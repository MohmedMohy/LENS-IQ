{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0",

    "strict": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@domain/*": ["packages/domain/src/*"],
      "@engine/*": ["packages/engine/src/*"],
      "@db/*": ["packages/db/src/*"],
      "@shared/*": ["packages/shared/src/*"]
    }
  }
}