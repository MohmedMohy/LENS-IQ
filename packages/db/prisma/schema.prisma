generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  UNDER_REVIEW
}

enum JobType {
  private
  government
  corporate
  freelancer
  retired
}

enum VehicleCondition {
  new
  used
}

enum VehicleCategory {
  sedan
  suv
  truck
  van
  microbus
}

enum FinancingType {
  conventional
  islamic
}

enum CalculationMethod {
  reducing
  flat
  murabaha
}

enum AllowedConditions {
  new
  used
  both
}

enum PaymentMethod {
  salary_transfer
  bank_account
  cash_proof
}

enum Role {
  ADMIN
  MANAGER
  SALES_AGENT
}

enum CustomerType {
  salary_transfer
  employee
  self_employed
}

model Tenant {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  api_key_hash  String   @unique
  role          Role     @default(SALES_AGENT)
  active        Boolean  @default(true)
  max_users     Int      @default(99)
  created_at    DateTime @default(now())

  banks          Bank[]
  programs       Program[]
  rules          Rule[]
  customers      Customer[]
  vehicles       Vehicle[]
  applications   Application[]
  offers         Offer[]
  refresh_tokens RefreshToken[]
  users            User[]
  audit_logs       AuditLog[]
  scoring_profiles ScoringProfile[]

  @@map("tenants")
}

model User {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  manager_id    Int?
  name          String
  email         String
  password_hash String
  role          Role     @default(SALES_AGENT)
  active        Boolean  @default(true)
  created_at    DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  manager        User?           @relation("UserManager", fields: [manager_id], references: [id])
  subordinates   User[]          @relation("UserManager")
  refresh_tokens RefreshToken[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@map("users")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  user_id    Int?
  user_type  String   @default("tenant")
  action     String
  entity     String
  entity_id  Int?
  details    Json?
  ip_address String?
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, created_at])
  @@map("audit_logs")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  user_id    Int?
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model ScoringProfile {
  id          Int      @id @default(autoincrement())
  tenant_id   Int?
  name        String
  type        String   @default("RISK")
  base_score  Float    @default(0)
  thresholds  Json?
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  tenant Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rules  ScoringProfileRule[]

  @@index([tenant_id])
  @@index([tenant_id, type, active])
  @@map("scoring_profiles")
}

model ScoringProfileRule {
  id               Int      @id @default(autoincrement())
  profile_id       Int
  field            String
  operator         String
  value            String
  score_adjustment Float
  max_adjustment   Float?
  priority         Int      @default(0)
  conditions       Json?

  profile ScoringProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@map("scoring_profile_rules")
}

model Bank {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  code       String
  logo_url   String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  programs ProgramBank[]
  offers   Offer[]

  @@index([tenant_id])
  @@unique([tenant_id, code])
  @@map("banks")
}

model Program {
  id                       Int               @id @default(autoincrement())
  tenant_id                Int
  name                     String
  code                     String?
  description              String?
  customer_types           CustomerType[]
  required_documents       Json?

  financing_type           FinancingType      @default(conventional)
  calculation_method       CalculationMethod  @default(reducing)

  min_salary               Float
  max_customer_age         Int
  salary_transfer_required  Boolean           @default(false)
  max_car_age              Int               @default(0)
  allowed_conditions       AllowedConditions  @default(both)
  max_vehicle_price        Float?
  interest_rate           Float             @default(0)
  profit_rate             Float?
  min_months               Int               @default(12)
  max_months               Int
  min_down_payment_percent  Float
  max_down_payment_percent  Float             @default(100)
  max_finance_amount       Float?
  admin_fees_percent       Float             @default(0)
  default_risk_rules       Json?
  max_ltv_percent          Float?

  active                   Boolean           @default(true)
  created_at               DateTime          @default(now())
  updated_at               DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  banks  ProgramBank[]
  rules  Rule[]
  offers Offer[]

  @@index([tenant_id])
  @@index([tenant_id, active])
  @@map("programs")
}

model ProgramBank {
  program_id              Int
  bank_id                 Int

  interest_rate           Float             @default(0)
  profit_rate             Float?
  min_months              Int               @default(12)
  max_months              Int
  min_down_payment_percent Float
  max_down_payment_percent Float            @default(100)
  max_finance_amount      Float?
  admin_fees_percent      Float             @default(0)
  max_car_age             Int               @default(0)
  max_vehicle_price       Float?
  max_ltv_percent         Float?
  active                  Boolean           @default(true)

  program Program @relation(fields: [program_id], references: [id], onDelete: Cascade)
  bank    Bank    @relation(fields: [bank_id], references: [id], onDelete: Cascade)

  @@id([program_id, bank_id])
  @@index([program_id])
  @@index([bank_id])
  @@map("program_banks")
}

model Rule {
  id          Int    @id @default(autoincrement())
  tenant_id   Int
  program_id  Int
  scope       String @default("PROGRAM")
  field       String
  operator    String
  value       String
  action      String
  priority    Int    @default(0)

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  program Program @relation(fields: [program_id], references: [id])

  @@index([tenant_id])
  @@index([program_id])
  @@map("rules")
}

model Customer {
  id                      Int        @id @default(autoincrement())
  tenant_id               Int
  name                    String
  national_id             String
  phone                   String
  birth_date              String
  salary                  Float
  job_type                JobType    @default(private)
  current_liabilities     Float      @default(0)
  additional_income       Float      @default(0)
  employer_name           String?
  employment_tenure_months Int?
  insurance_number        String?
  club_membership         String?
  marital_status          String?
  owns_property           Boolean    @default(false)
  owns_car                Boolean    @default(false)
  salary_transfer         Boolean    @default(false)
  tax_card                String?
  commercial_registry     String?
  created_at              DateTime   @default(now())

  tenant       Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([tenant_id])
  @@index([tenant_id, name])
  @@index([tenant_id, national_id])
  @@map("customers")
}

model Vehicle {
  id                 Int              @id @default(autoincrement())
  tenant_id          Int
  brand              String
  model              String
  manufacturing_year Int
  condition          VehicleCondition @default(used)
  price              Float
  category           VehicleCategory
  created_at         DateTime         @default(now())

  tenant       Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([tenant_id])
  @@index([tenant_id, brand, model])
  @@map("vehicles")
}

model Application {
  id                      Int               @id @default(autoincrement())
  tenant_id               Int
  customer_id             Int
  vehicle_id              Int
  requested_down_payment  Float
  requested_months        Int
  payment_method          PaymentMethod     @default(bank_account)
  status                  ApplicationStatus @default(PENDING)
  notes                   String?
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [id])
  offers   Offer[]

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@index([customer_id])
  @@index([vehicle_id])
  @@map("applications")
}

model Offer {
  id                  Int               @id @default(autoincrement())
  tenant_id           Int
  application_id      Int
  program_id          Int
  bank_id             Int
  status              ApplicationStatus @default(PENDING)
  installment         Float             @default(0)
  total_payment       Float             @default(0)
  finance_amount      Float             @default(0)
  down_payment        Float             @default(0)
  interest_rate       Float             @default(0)
  months              Int               @default(0)
  dti                 Float             @default(0)
  risk_score          Float             @default(0)
  risk_level          String            @default("LOW")
  affordability_score Float             @default(0)
  reasons             Json?
  created_at          DateTime          @default(now())

  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  application Application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  program     Program     @relation(fields: [program_id], references: [id], onDelete: Cascade)
  bank        Bank        @relation(fields: [bank_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@index([application_id])
  @@index([program_id])
  @@index([bank_id])
  @@map("offers")
}

model FinancierSubmission {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  application_id  Int
  offer_id        Int?
  bank_name       String
  program_name    String
  status          String   @default("PENDING")
  financier_notes String?
  submitted_at    DateTime @default(now())
  decided_at      DateTime?

  @@index([tenant_id])
  @@index([application_id])
  @@index([tenant_id, application_id])
  @@map("financier_submissions")
}
