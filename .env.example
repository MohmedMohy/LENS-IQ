# Database (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/db

# JWT Secrets — CHANGE THESE in production (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=
REFRESH_TOKEN_SECRET=
COOKIE_SECRET=

# PII Encryption Key — 64-char hex (32 bytes). Required for production.
ENCRYPTION_KEY=

# Token expiry
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=production
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — comma-separated origins for production
CORS_ORIGINS=https://yourdomain.com

# Frontend API URL (for Vite)
VITE_API_URL=

# PostgreSQL SSL mode (Railway: require)
PGSSLMODE=require
